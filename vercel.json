{
  "version": 2,
  "builds": [
    {
      "src": "backend/ecosphere/wsgi.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/ecosphere/wsgi.py"
    },
    {
      "source": "/(assets/.*|.*\\.(svg|ico|png|jpg|jpeg|gif|css|js))",
      "destination": "/frontend/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/index.html"
    }
  ]
}
